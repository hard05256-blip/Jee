<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>JEE://PROTOCOL — Rank Engine v1.0</title>
<style>
  * { margin: 0; padding: 0; box-sizing: border-box; }
  
  :root {
    --bg: #0a0e1a;
    --bg-2: #0f1424;
    --panel: #131a2e;
    --border: #1f2a44;
    --accent: #00ffc6;
    --accent-2: #7c5cff;
    --danger: #ff3860;
    --warn: #ffb020;
    --text: #e4ecff;
    --dim: #7a86a8;
  }
  
  body {
    font-family: 'Courier New', monospace;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    background-image: 
      radial-gradient(circle at 20% 10%, rgba(124,92,255,0.08), transparent 40%),
      radial-gradient(circle at 80% 90%, rgba(0,255,198,0.06), transparent 40%);
  }
  
  .container { max-width: 1400px; margin: 0 auto; padding: 20px; }
  
  /* HEADER */
  header {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 16px 24px;
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 20px;
  }
  .logo { font-size: 20px; font-weight: bold; color: var(--accent); letter-spacing: 2px; }
  .logo span { color: var(--dim); }
  .status-pill {
    display: inline-block;
    padding: 4px 12px;
    border: 1px solid var(--accent);
    color: var(--accent);
    font-size: 11px;
    letter-spacing: 1px;
  }
  .status-pill.danger { border-color: var(--danger); color: var(--danger); animation: pulse 1.5s infinite; }
  @keyframes pulse { 0%,100% { opacity: 1; } 50% { opacity: 0.4; } }
  
  /* GRID */
  .grid {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 16px;
    margin-bottom: 20px;
  }
  .grid-2 { display: grid; grid-template-columns: 2fr 1fr; gap: 16px; margin-bottom: 20px; }
  
  .panel {
    border: 1px solid var(--border);
    background: var(--panel);
    padding: 20px;
    position: relative;
  }
  .panel-title {
    font-size: 10px;
    letter-spacing: 2px;
    color: var(--dim);
    margin-bottom: 12px;
    display: flex;
    justify-content: space-between;
  }
  .panel-title .dot {
    width: 8px; height: 8px;
    background: var(--accent);
    border-radius: 50%;
    box-shadow: 0 0 8px var(--accent);
  }
  
  /* STATS */
  .stat-big { font-size: 42px; font-weight: bold; color: var(--accent); }
  .stat-sub { font-size: 12px; color: var(--dim); margin-top: 4px; }
  .stat-delta { font-size: 14px; margin-top: 8px; }
  .delta-up { color: var(--accent); }
  .delta-down { color: var(--danger); }
  
  /* STREAK */
  .streak-flame {
    font-size: 48px;
    text-align: center;
    animation: flicker 2s infinite;
  }
  @keyframes flicker { 0%,100% { transform: scale(1); } 50% { transform: scale(1.05); } }
  .streak-warning {
    background: rgba(255,56,96,0.1);
    border: 1px solid var(--danger);
    padding: 8px;
    margin-top: 10px;
    font-size: 11px;
    color: var(--danger);
    text-align: center;
  }
  
  /* PROGRESS BAR */
  .progress-container { margin: 12px 0; }
  .progress-label { display: flex; justify-content: space-between; font-size: 11px; margin-bottom: 4px; }
  .progress-bar {
    height: 8px;
    background: var(--bg);
    border: 1px solid var(--border);
    overflow: hidden;
    position: relative;
  }
  .progress-fill {
    height: 100%;
    background: linear-gradient(90deg, var(--accent-2), var(--accent));
    transition: width 0.6s ease;
    box-shadow: 0 0 10px var(--accent);
  }
  
  /* LEADERBOARD */
  .leaderboard-row {
    display: grid;
    grid-template-columns: 40px 1fr 80px 60px;
    padding: 8px;
    font-size: 12px;
    border-bottom: 1px solid var(--border);
    align-items: center;
  }
  .leaderboard-row.you {
    background: rgba(0,255,198,0.08);
    border-left: 3px solid var(--accent);
  }
  .leaderboard-row.target { color: var(--warn); }
  
  /* QUESTION AREA */
  .question-panel {
    min-height: 300px;
    display: flex;
    flex-direction: column;
  }
  .question-text {
    font-size: 16px;
    line-height: 1.6;
    margin: 16px 0;
    padding: 16px;
    background: var(--bg);
    border-left: 3px solid var(--accent-2);
  }
  .difficulty-tag {
    display: inline-block;
    padding: 2px 10px;
    font-size: 10px;
    letter-spacing: 1px;
    margin-bottom: 8px;
  }
  .diff-easy { background: rgba(0,255,198,0.15); color: var(--accent); }
  .diff-mid { background: rgba(255,176,32,0.15); color: var(--warn); }
  .diff-hard { background: rgba(255,56,96,0.15); color: var(--danger); }
  .diff-legendary { 
    background: linear-gradient(90deg, var(--accent-2), var(--danger));
    color: white;
    animation: shimmer 2s infinite;
  }
  @keyframes shimmer { 0%,100% { opacity: 1; } 50% { opacity: 0.7; } }
  
  .options { display: grid; gap: 8px; margin-top: 12px; }
  .option-btn {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 12px 16px;
    text-align: left;
    cursor: pointer;
    font-family: inherit;
    font-size: 13px;
    transition: all 0.2s;
  }
  .option-btn:hover { border-color: var(--accent); background: rgba(0,255,198,0.05); }
  .option-btn.correct { border-color: var(--accent); background: rgba(0,255,198,0.15); }
  .option-btn.wrong { border-color: var(--danger); background: rgba(255,56,96,0.15); }
  
  /* BUTTONS */
  .btn {
    background: transparent;
    border: 1px solid var(--accent);
    color: var(--accent);
    padding: 10px 20px;
    cursor: pointer;
    font-family: inherit;
    letter-spacing: 1px;
    font-size: 12px;
    transition: all 0.2s;
  }
  .btn:hover { background: var(--accent); color: var(--bg); box-shadow: 0 0 20px var(--accent); }
  .btn-primary {
    background: var(--accent);
    color: var(--bg);
    font-weight: bold;
  }
  .btn-row { display: flex; gap: 10px; margin-top: 12px; }
  
  /* TIMER */
  .timer {
    font-size: 36px;
    font-weight: bold;
    color: var(--accent-2);
    text-align: center;
    text-shadow: 0 0 15px var(--accent-2);
  }
  
  /* NOTIFICATION */
  .notification {
    position: fixed;
    top: 20px;
    right: 20px;
    background: var(--panel);
    border: 1px solid var(--danger);
    padding: 16px 20px;
    min-width: 300px;
    box-shadow: 0 4px 20px rgba(0,0,0,0.5);
    animation: slideIn 0.3s;
    z-index: 1000;
  }
  .notification.success { border-color: var(--accent); }
  @keyframes slideIn { from { transform: translateX(400px); } to { transform: translateX(0); } }
  .notif-title { font-size: 11px; letter-spacing: 2px; color: var(--dim); margin-bottom: 6px; }
  .notif-body { font-size: 14px; }
  
  /* XP POPUP */
  .xp-popup {
    position: fixed;
    color: var(--accent);
    font-size: 20px;
    font-weight: bold;
    pointer-events: none;
    animation: xpFloat 1.5s ease-out forwards;
    z-index: 999;
    text-shadow: 0 0 10px var(--accent);
  }
  @keyframes xpFloat {
    0% { transform: translateY(0); opacity: 1; }
    100% { transform: translateY(-80px); opacity: 0; }
  }
  
  /* ACHIEVEMENTS */
  .achievement {
    display: flex;
    align-items: center;
    gap: 10px;
    padding: 8px;
    border: 1px solid var(--border);
    margin-bottom: 6px;
    font-size: 12px;
  }
  .achievement.unlocked { border-color: var(--accent); background: rgba(0,255,198,0.05); }
  .achievement.locked { opacity: 0.4; }
  .ach-icon { font-size: 20px; }
  
  /* IDENTITY */
  .identity-panel { text-align: center; }
  .identity-rank {
    font-size: 14px;
    letter-spacing: 3px;
    color: var(--accent);
    margin: 8px 0;
  }
  .identity-name {
    font-size: 24px;
    font-weight: bold;
    margin: 8px 0;
  }
  
  /* AMBIENT WORLD */
  .world-tick {
    font-size: 10px;
    color: var(--dim);
    font-style: italic;
    margin-top: 8px;
  }
  
  /* ONBOARDING */
  .modal-bg {
    position: fixed;
    inset: 0;
    background: rgba(5,8,15,0.9);
    display: flex;
    align-items: center;
    justify-content: center;
    z-index: 2000;
  }
  .modal {
    background: var(--panel);
    border: 1px solid var(--accent);
    padding: 40px;
    max-width: 500px;
    text-align: center;
  }
  .modal h2 { color: var(--accent); margin-bottom: 20px; letter-spacing: 2px; }
  .modal input {
    background: var(--bg);
    border: 1px solid var(--border);
    color: var(--text);
    padding: 10px;
    width: 100%;
    margin: 10px 0;
    font-family: inherit;
  }
  
  @media (max-width: 900px) {
    .grid, .grid-2 { grid-template-columns: 1fr; }
  }
</style>
</head>
<body>

<div id="onboarding" class="modal-bg" style="display:none;">
  <div class="modal">
    <h2>⟢ INITIALIZE PROTOCOL</h2>
    <p style="color: var(--dim); font-size: 12px; margin-bottom: 20px;">ENTER OPERATIVE DESIGNATION</p>
    <input id="nameInput" placeholder="your name" maxlength="20">
    <button class="btn btn-primary" onclick="completeOnboarding()" style="width:100%; margin-top:10px;">BEGIN MISSION</button>
  </div>
</div>

<div class="container">
  
  <header>
    <div class="logo">JEE://<span>PROTOCOL</span></div>
    <div>
      <span class="status-pill" id="statusPill">● SYSTEM ONLINE</span>
    </div>
  </header>

  <!-- TOP STATS -->
  <div class="grid">
    <div class="panel">
      <div class="panel-title">CURRENT RANK <span class="dot"></span></div>
      <div class="stat-big" id="rankDisplay">—</div>
      <div class="stat-sub">of 1,200,000 aspirants</div>
      <div class="stat-delta" id="rankDelta"></div>
    </div>
    
    <div class="panel">
      <div class="panel-title">STREAK COUNTER 🔥</div>
      <div class="streak-flame" id="streakFlame">🔥</div>
      <div class="stat-big" style="font-size:28px;" id="streakDays">0 DAYS</div>
      <div class="streak-warning" id="streakWarning" style="display:none;">
        ⚠ STREAK EXPIRES IN <span id="streakCountdown">--:--:--</span>
      </div>
    </div>
    
    <div class="panel identity-panel">
      <div class="panel-title">OPERATIVE ID</div>
      <div class="identity-name" id="identityName">—</div>
      <div class="identity-rank" id="identityTier">RECRUIT</div>
      <div class="stat-sub">XP: <span id="xpDisplay">0</span></div>
      <div class="progress-container">
        <div class="progress-bar"><div class="progress-fill" id="xpBar" style="width:0%;"></div></div>
        <div class="stat-sub" id="xpNext">next tier: 100 XP</div>
      </div>
    </div>
  </div>

  <!-- MAIN ROW -->
  <div class="grid-2">
    
    <!-- QUESTION ENGINE -->
    <div class="panel question-panel">
      <div class="panel-title">QUESTION ENGINE [LAYER_01: VARIABLE REWARD]</div>
      <div id="questionArea">
        <div class="difficulty-tag diff-mid" id="diffTag">MEDIUM</div>
        <div class="question-text" id="questionText">Press START to begin session.</div>
        <div class="options" id="optionsArea"></div>
      </div>
      <div class="btn-row">
        <button class="btn btn-primary" onclick="nextQuestion()">▶ NEXT QUESTION</button>
        <button class="btn" onclick="startPomodoro()">⏱ START POMODORO</button>
      </div>
      <div class="timer" id="pomodoroTimer" style="margin-top:16px; display:none;">25:00</div>
    </div>
    
    <!-- LEADERBOARD -->
    <div class="panel">
      <div class="panel-title">BATCH LEADERBOARD [LAYER_04]</div>
      <div id="leaderboardList"></div>
      <div class="world-tick" id="worldTick">● ambient world active</div>
    </div>
  </div>

  <!-- BOTTOM ROW -->
  <div class="grid">
    
    <!-- PROGRESS -->
    <div class="panel">
      <div class="panel-title">MASTERY PROGRESSION [LAYER_03]</div>
      <div class="progress-container">
        <div class="progress-label"><span>PHYSICS</span><span id="physLabel">67%</span></div>
        <div class="progress-bar"><div class="progress-fill" id="physBar" style="width:67%"></div></div>
      </div>
      <div class="progress-container">
        <div class="progress-label"><span>CHEMISTRY</span><span id="chemLabel">54%</span></div>
        <div class="progress-bar"><div class="progress-fill" id="chemBar" style="width:54%"></div></div>
      </div>
      <div class="progress-container">
        <div class="progress-label"><span>MATHEMATICS</span><span id="mathLabel">71%</span></div>
        <div class="progress-bar"><div class="progress-fill" id="mathBar" style="width:71%"></div></div>
      </div>
      <div class="stat-sub" style="margin-top:10px;">⚠ never reaches 100% — mastery is infinite</div>
    </div>
    
    <!-- ACHIEVEMENTS -->
    <div class="panel">
      <div class="panel-title">ACHIEVEMENTS [LAYER_05: MICRO-WINS]</div>
      <div id="achievementsList"></div>
    </div>
    
    <!-- SESSION STATS -->
    <div class="panel">
      <div class="panel-title">SESSION TELEMETRY</div>
      <div style="font-size: 12px; line-height: 2;">
        QUESTIONS SOLVED: <span style="color:var(--accent); float:right;" id="qSolved">0</span><br>
        CORRECT: <span style="color:var(--accent); float:right;" id="qCorrect">0</span><br>
        ACCURACY: <span style="color:var(--accent); float:right;" id="qAccuracy">0%</span><br>
        TIME INVESTED: <span style="color:var(--accent); float:right;" id="timeInvested">0 min</span><br>
        TOTAL SESSIONS: <span style="color:var(--accent); float:right;" id="totalSessions">0</span>
      </div>
      <button class="btn" style="width:100%; margin-top:16px;" onclick="resetData()">⟲ RESET SYSTEM</button>
    </div>
  </div>

</div>

<script>
/* ============================================
   JEE PROTOCOL — CORE ENGINE
   Implements all 10 addiction layers
   ============================================ */

// STATE
let state = JSON.parse(localStorage.getItem('jeeProtocol')) || {
  name: null,
  rank: 847293,
  streak: 0,
  lastStudy: null,
  xp: 0,
  tier: 'RECRUIT',
  progress: { physics: 12, chemistry: 8, math: 15 },
  sessions: 0,
  solved: 0,
  correct: 0,
  timeInvested: 0,
  achievements: {},
  onboarded: false,
  firstWeek: true,
};

const TIERS = [
  { name: 'RECRUIT', xp: 0 },
  { name: 'CADET', xp: 100 },
  { name: 'OPERATIVE', xp: 300 },
  { name: 'SPECIALIST', xp: 700 },
  { name: 'ELITE', xp: 1500 },
  { name: 'RANKER', xp: 3000 },
  { name: 'LEGEND', xp: 6000 },
];

const ACHIEVEMENTS = [
  { id: 'first', icon: '🎯', name: 'First Blood', desc: 'Solve your first question', check: s => s.solved >= 1 },
  { id: 'streak3', icon: '🔥', name: '3-Day Streak', desc: 'Study 3 days in a row', check: s => s.streak >= 3 },
  { id: 'streak7', icon: '⚡', name: 'Week Warrior', desc: 'Study 7 days in a row', check: s => s.streak >= 7 },
  { id: 'solved10', icon: '💯', name: 'Century', desc: 'Solve 10 questions', check: s => s.solved >= 10 },
  { id: 'solved50', icon: '🏆', name: 'Half Century', desc: 'Solve 50 questions', check: s => s.solved >= 50 },
  { id: 'acc80', icon: '🎖', name: 'Sharpshooter', desc: '80% accuracy (10+ Qs)', check: s => s.solved >= 10 && (s.correct/s.solved) >= 0.8 },
  { id: 'rank100k', icon: '📈', name: 'Top 100K', desc: 'Reach rank under 100,000', check: s => s.rank < 100000 },
  { id: 'rank10k', icon: '⭐', name: 'Top 10K', desc: 'Reach rank under 10,000', check: s => s.rank < 10000 },
];

// QUESTION BANK
const QUESTIONS = [
  { subj: 'physics', diff: 'easy', q: 'A body is thrown vertically upward with velocity 20 m/s. Max height reached? (g=10)',
    opts: ['10 m', '20 m', '30 m', '40 m'], ans: 1 },
  { subj: 'physics', diff: 'mid', q: 'A charge q is placed at center of cube. Flux through one face?',
    opts: ['q/ε₀', 'q/6ε₀', 'q/4ε₀', 'q/8ε₀'], ans: 1 },
  { subj: 'physics', diff: 'hard', q: 'In Young\'s double slit, slit separation d, screen at D. If λ doubles, fringe width:',
    opts: ['halves', 'doubles', 'unchanged', 'quadruples'], ans: 1 },
  { subj: 'physics', diff: 'legendary', q: 'A rod of length L rotates about one end with ω. EMF induced in magnetic field B (perpendicular)?',
    opts: ['BLω', 'BL²ω', 'BL²ω/2', '2BL²ω'], ans: 2 },
  { subj: 'chemistry', diff: 'easy', q: 'Number of moles in 22g of CO₂?',
    opts: ['0.5', '1', '1.5', '2'], ans: 0 },
  { subj: 'chemistry', diff: 'mid', q: 'Which has highest boiling point?',
    opts: ['HF', 'HCl', 'HBr', 'HI'], ans: 0 },
  { subj: 'chemistry', diff: 'hard', q: 'IUPAC name of CH₃-CH(OH)-CH₂-CHO:',
    opts: ['3-hydroxybutanal', '2-hydroxybutanal', '3-hydroxybutan-2-ol', '4-hydroxybutanal'], ans: 0 },
  { subj: 'math', diff: 'easy', q: 'Derivative of sin(x²)?',
    opts: ['cos(x²)', '2x·cos(x²)', '2x·sin(x²)', 'x·cos(x²)'], ans: 1 },
  { subj: 'math', diff: 'mid', q: '∫(1/(1+x²))dx =',
    opts: ['ln(1+x²)', 'tan⁻¹(x)', 'sin⁻¹(x)', '1/(2x)'], ans: 1 },
  { subj: 'math', diff: 'hard', q: 'Number of solutions of sin(x) = x/10 in [0, 10π]?',
    opts: ['3', '5', '7', '10'], ans: 2 },
  { subj: 'math', diff: 'legendary', q: 'lim(x→0) (sin x - x)/x³ =',
    opts: ['0', '-1/6', '1/6', '-1/3'], ans: 1 },
];

const BATCHMATES = [
  'ARJUN_K', 'PRIYA_S', 'ROHAN_M', 'ANANYA_R', 'KARTIK_J',
  'ISHITA_P', 'VIKRAM_D', 'SANYA_G', 'ADITYA_N', 'MEGHA_T'
];

let currentQuestion = null;
let pomodoroInterval = null;
let streakInterval = null;
let worldInterval = null;

// =====================
// INITIALIZATION
// =====================
function init() {
  if (!state.onboarded) {
    document.getElementById('onboarding').style.display = 'flex';
    return;
  }
  render();
  checkStreak();
  startAmbientWorld();
  startStreakCountdown();
  scheduleNotifications();
  initLeaderboard();
}

function completeOnboarding() {
  const name = document.getElementById('nameInput').value.trim() || 'OPERATIVE';
  state.name = name.toUpperCase();
  state.onboarded = true;
  state.lastStudy = Date.now();
  save();
  document.getElementById('onboarding').style.display = 'none';
  notify('success', 'ONBOARDING COMPLETE', `Welcome, ${state.name}. First mission loaded.`);
  setTimeout(() => {
    notify('success', 'BEGINNER BONUS', '+50 XP · Early momentum activated');
    state.xp += 50;
    save(); render();
  }, 2000);
  init();
}

// =====================
// LAYER 1: VARIABLE REWARD (questions)
// =====================
function nextQuestion() {
  // Early-game bias (Layer 9: beginner's luck)
  let pool = QUESTIONS;
  if (state.firstWeek && state.solved < 5) {
    pool = QUESTIONS.filter(q => q.diff === 'easy' || q.diff === 'mid');
  }
  currentQuestion = pool[Math.floor(Math.random() * pool.length)];
  
  const diffMap = { easy: 'diff-easy', mid: 'diff-mid', hard: 'diff-hard', legendary: 'diff-legendary' };
  const diffLabel = { easy: 'EASY', mid: 'MEDIUM', hard: 'HARD', legendary: '⚡ LEGENDARY' };
  
  const tag = document.getElementById('diffTag');
  tag.className = 'difficulty-tag ' + diffMap[currentQuestion.diff];
  tag.textContent = diffLabel[currentQuestion.diff];
  
  document.getElementById('questionText').textContent = `[${currentQuestion.subj.toUpperCase()}] ${currentQuestion.q}`;
  
  const optsHtml = currentQuestion.opts.map((opt, i) => 
    `<button class="option-btn" onclick="answerQuestion(${i}, this)">${String.fromCharCode(65+i)}) ${opt}</button>`
  ).join('');
  document.getElementById('optionsArea').innerHTML = optsHtml;
}

function answerQuestion(choice, btn) {
  const isCorrect = choice === currentQuestion.ans;
  state.solved++;
  
  const rewardMap = { easy: 10, mid: 20, hard: 40, legendary: 100 };
  
  if (isCorrect) {
    btn.classList.add('correct');
    state.correct++;
    const xp = rewardMap[currentQuestion.diff];
    state.xp += xp;
    state.progress[currentQuestion.subj] += Math.random() * 2;
    
    // Variable reward bonus
    if (Math.random() < 0.15) {
      state.xp += 25;
      notify('success', '🎰 BONUS DROP', '+25 XP unexpected reward');
    }
    
    showXpPopup(btn, xp);
    improveRank(Math.floor(Math.random() * 500) + 100);
  } else {
    btn.classList.add('wrong');
    document.querySelectorAll('.option-btn')[currentQuestion.ans].classList.add('correct');
    worsenRank(Math.floor(Math.random() * 200) + 50);
  }
  
  // Disable buttons
  document.querySelectorAll('.option-btn').forEach(b => b.disabled = true);
  
  updateTie
